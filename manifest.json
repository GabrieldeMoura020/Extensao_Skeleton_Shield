{
  "manifest_version": 3,
  "name": "Skeleton Shield",
  "version": "1.0",
  "description": "Proteção lendária contra notificações 💀🛡️",
  "web_accessible_resources": [
    {
      "resources": ["skeleton.gif"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "scripting",
    "activeTab",
    "notifications"
  ]
}