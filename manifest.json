{
  "manifest_version": 3,
  "name": "Skeleton Shield",
  "version": "1.1",
  "description": "Proteção lendária 💀🛡️",
  "permissions": ["scripting", "activeTab", "notifications"],
  "web_accessible_resources": [
    {
      "resources": ["skeleton.gif", "interceptor.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}
